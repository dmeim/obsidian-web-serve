{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-07-17",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "web-serve-landing",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"preview_urls": true,
	"workers_dev": true,
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
